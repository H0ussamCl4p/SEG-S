# =============================================================
# PRODUCTION ENVIRONMENT — EDIT BEFORE DEPLOYING
# =============================================================

# ---- Security (REQUIRED: change both values) ----------------
JWT_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- AI / Chatbot --------------------------------------------
# Vector store is local (ChromaDB embedded, persisted to ai-engine data volume).
#
# LLM is OpenAI-compatible. Two options:
#   A) Cloud (DeepSeek) — recommended for Azure, no GPU:
#        LLM_API_BASE=https://api.deepseek.com
#        LLM_MODEL=deepseek-chat
#        LLM_API_KEY=sk-...            (or set DEEPSEEK_API_KEY)
#      When using DeepSeek you can stop the ollama/ollama-puller containers.
#   B) Local (Ollama / Gemma) — leave LLM_API_BASE empty:
#        LLM_MODEL=gemma4:e2b
#        OLLAMA_BASE_URL=http://ollama:11434/v1
LLM_API_BASE=
LLM_API_KEY=
DEEPSEEK_API_KEY=
LLM_MODEL=gemma4:e2b
OLLAMA_BASE_URL=http://ollama:11434/v1

# ---- Database credentials (change if desired) ---------------
POSTGRES_USER=iiot_admin
POSTGRES_PASSWORD=iiot_db_pass_123
POSTGRES_DB=iiot_users

INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=admin123
INFLUXDB_DB=factory_data

# ---- Frontend public URLs — MUST match your public domains ----
# NOTE: do NOT add /api or /auth suffixes — the frontend code adds those itself.
NEXT_PUBLIC_API_URL=https://api.eneguardian.app
NEXT_PUBLIC_AUTH_URL=https://auth.eneguardian.app
